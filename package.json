    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
